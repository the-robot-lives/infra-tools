#!/usr/bin/env bash
# add-import-permissions: Replaces the terraformer-import inline policy with the
# canonical version stored in terraform/production/imported/iam/terraformer-import-policy.json
#
# Usage: ./utils/add-import-permissions [--profile PROFILE] [--dry-run]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INFRA_ROOT="${INFRA_ROOT:-$(pwd)}"
POLICY_FILE="$INFRA_ROOT/terraform/production/imported/iam/terraformer-import-policy.json"

PROFILE="${PROFILE:-${K8_AWS_PROFILE:-terraformer}}"
USER_NAME="terraformer-import"
POLICY_NAME="TerraformerImportPolicy"
DRY_RUN=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --profile) PROFILE="$2"; shift 2 ;;
    --dry-run) DRY_RUN=true; shift ;;
    *) echo "Unknown arg: $1"; exit 1 ;;
  esac
done

if [[ ! -f "$POLICY_FILE" ]]; then
  echo "ERROR: Policy file not found: $POLICY_FILE"
  exit 1
fi

POLICY_DOC=$(cat "$POLICY_FILE")
ACTION_COUNT=$(python3 -c "import json,sys; p=json.loads(sys.stdin.read()); print(sum(len(s['Action']) for s in p['Statement']))" <<< "$POLICY_DOC")

echo "==> Policy file: $POLICY_FILE"
echo "==> Total actions: $ACTION_COUNT"

if $DRY_RUN; then
  echo "==> [DRY RUN] Would apply to user: $USER_NAME / policy: $POLICY_NAME (profile: $PROFILE)"
  exit 0
fi

echo "==> Applying to $USER_NAME / $POLICY_NAME (profile: $PROFILE) ..."
aws iam put-user-policy \
  --user-name "$USER_NAME" \
  --policy-name "$POLICY_NAME" \
  --policy-document "$POLICY_DOC" \
  --profile "$PROFILE"

echo "==> Done."
