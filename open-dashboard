#!/usr/bin/env bash
# Opens a monitoring dashboard via kubectl port-forward.
# Usage: open-dashboard [goldilocks|kubecost|parca|signoz]
set -euo pipefail

TOOL="${1:-}"

_usage() {
  echo "Usage: open-dashboard <tool>"
  echo ""
  echo "Available dashboards:"
  echo "  goldilocks  — VPA resource recommendations (port 8080)"
  echo "  kubecost    — Cost allocation & right-sizing (port 9090)"
  echo "  parca       — Continuous profiling / flamegraphs (port 7070)"
  echo "  signoz      — Observability / traces / metrics (port 3301)"
  exit 1
}

[[ -z "$TOOL" ]] && _usage

case "$TOOL" in
  goldilocks)
    NS="${K8_GOLDILOCKS_NS:-goldilocks}"; SVC="svc/${K8_GOLDILOCKS_SVC:-goldilocks-dashboard}"; PORT="8080:80"
    ;;
  kubecost)
    NS="${K8_KUBECOST_NS:-kubecost}"; SVC="svc/${K8_KUBECOST_SVC:-kubecost-cost-analyzer}"; PORT="9090:9090"
    ;;
  parca)
    NS="${K8_PARCA_NS:-parca}"; SVC="svc/${K8_PARCA_SVC:-parca-server}"; PORT="7070:7070"
    ;;
  signoz)
    NS="${K8_SIGNOZ_NS:-infra}"; SVC="svc/${K8_SIGNOZ_SVC:-signoz-frontend}"; PORT="3301:3301"
    ;;
  *)
    echo "Unknown dashboard: $TOOL"
    _usage
    ;;
esac

echo "Port-forwarding $TOOL → http://localhost:${PORT%%:*}"
echo "Press Ctrl-C to stop."
echo ""

open "http://localhost:${PORT%%:*}" 2>/dev/null || true
kubectl port-forward -n "$NS" "$SVC" "$PORT"
